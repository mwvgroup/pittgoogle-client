            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Uncertainty in trailFlux (stub) [nJy]",
            "name": "trailFluxErr",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
