            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Adaptive second moment Iyy (stub) [arcsec^2]",
            "name": "iyy",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Adaptive second moment Ixy (stub) [arcsec^2]",
