            "type": "float"
          },
          {
            "doc": "y-pixel position on detector [pixels]",
            "name": "y",
            "type": "float"
          },
          {
            "default": null,
            "doc": "Uncertainty in x [pixels]",
            "name": "xErr",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Uncertainty in y [pixels]",
            "name": "yErr",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Filter band name (F062, F087, F106, F129, F146, F158, F184, F213)",
            "name": "band",
            "type": [
              "null",
              "string"
            ]
          },
          {
            "default": null,
            "doc": "Flux from PSF-fit on difference image [nJy]",
            "name": "psfFlux",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Uncertainty in psfFlux [nJy]",
            "name": "psfFluxErr",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Signal-to-noise ratio (psfFlux / psfFluxErr)",
            "name": "snr",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Probability of being extended (stub)",
            "name": "extendedness",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "default": null,
            "doc": "Reliability score (stub)",
            "name": "reliability",
            "type": [
              "null",
              "float"
            ]
          },
          {
            "doc": "Bitmask of processing flags",
            "name": "flags",
            "type": "long"
          },
          {
            "default": null,
            "doc": "Aperture flux on difference image (stub) [nJy]",
